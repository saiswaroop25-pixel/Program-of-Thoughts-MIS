# Copy this file to .env and fill only the provider you want to use.

POT_PROVIDER=groq
POT_MODEL=llama-3.1-8b-instant

GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

POT_MAX_TOKENS=1024
POT_TEMPERATURE=0.0
POT_SC_SAMPLES=10
POT_CODE_TIMEOUT_SECS=10
POT_MAX_RETRIES=3
